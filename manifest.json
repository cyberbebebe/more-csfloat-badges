{
  "manifest_version": 3,
  "name": "More CSFloat Badges",
  "version": "2.2.0",
  "description": "Enhance CSFloat listings and sales with custom pattern tier badges for Marble Fade, Doppler, Gamma Doppler and more",
  "permissions": [],
  "host_permissions": ["https://csfloat.com/*"],
  "icons": {
    "16": "ext_icon/16.png",
    "48": "ext_icon/48.png",
    "128": "ext_icon/128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://csfloat.com/*"],
      "js": ["src/intercept.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://csfloat.com/*"],
      "css": ["styles/badge-styles.css"],
      "js": [
        "src/labels.js",
        "src/gradients.js",
        "src/patterns.js",
        "src/utils.js",
        "src/sales.js",
        "src/badges.js",
        "src/inject.js",
        "src/listings.js",
        "src/content.js"
      ],
      "run_at": "document_idle",
      "world": "ISOLATED"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["icons/*.png"],
      "matches": ["https://csfloat.com/*"]
    }
  ]
}
